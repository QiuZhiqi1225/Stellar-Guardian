<view class="page-shell">
  <view class="hero-cover">
    <view class="hero-kicker">EMERGENCY CONNECT</view>
    <view class="hero-title">紧急守护</view>
    <view class="hero-text">登录、登记、接警、回拨。</view>
    <view class="hero-badges">
      <text class="hero-badge">分页面</text>
      <text class="hero-badge">回拨</text>
      <text class="hero-badge">订阅预留</text>
    </view>
    <view class="hero-stats">
      <view class="hero-stat">
        <view class="hero-stat-value">3</view>
        <view class="hero-stat-label">底部分类</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">8</view>
        <view class="hero-stat-label">独立页面</view>
      </view>
      <view class="hero-stat">
        <view class="hero-stat-value">1</view>
        <view class="hero-stat-label">清晰主流程</view>
      </view>
    </view>
  </view>

  <view class="critical-alert-banner" wx:if="{{pendingCount > 0}}" bindtap="openLatestPendingAlert">
    <view class="critical-alert-kicker">FALL ALERT</view>
    <view class="critical-alert-title">收到跌倒告警</view>
    <view class="critical-alert-text">{{criticalBannerText || "当前存在待处理跌倒告警，请立即查看。"}}</view>
    <view class="critical-alert-action">点击立即查看告警详情</view>
  </view>

  <view class="stack-gap" style="margin-top: 24rpx;">
    <view class="shortcut-card shortcut-card-primary" bindtap="openAccount">
      <view class="shortcut-card-title">账号</view>
      <view class="shortcut-card-text">注册、登录、登记设备。</view>
      <view class="shortcut-arrow">进入账号中心 →</view>
    </view>

    <view class="shortcut-card shortcut-card-warm" bindtap="openAlerts">
      <view class="shortcut-card-title">告警</view>
      <view class="shortcut-card-text">查看待处理与历史会话。{{pendingSummary}}</view>
      <view class="shortcut-arrow">查看告警列表 →</view>
    </view>

    <view class="shortcut-card shortcut-card-calm" bindtap="openSettings">
      <view class="shortcut-card-title">配置</view>
      <view class="shortcut-card-text">设置后端并检测接口。</view>
      <view class="shortcut-arrow">打开系统配置 →</view>
    </view>
  </view>

  <view class="panel-card" style="margin-top: 24rpx;">
    <view class="section-heading">
      <view class="section-heading-text">当前状态</view>
    </view>
    <view class="mini-stat-grid">
      <view class="mini-stat-card">
        <view class="mini-stat-value">{{appUserId || "未登录"}}</view>
        <view class="mini-stat-label">当前用户</view>
      </view>
      <view class="mini-stat-card">
        <view class="mini-stat-value">{{recipientName || "未登记"}}</view>
        <view class="mini-stat-label">接收人</view>
      </view>
      <view class="mini-stat-card">
        <view class="mini-stat-value">{{pendingCount}}</view>
        <view class="mini-stat-label">待处理告警</view>
      </view>
    </view>
    <view class="meta-wrap" style="margin-top: 16rpx;">
      <text class="chip">后端：{{baseUrl}}</text>
      <text class="chip" wx:if="{{latestAlertTitle}}">最新：{{latestAlertTitle}}</text>
    </view>
  </view>

  <view class="bottom-nav">
    <view class="nav-tile" bindtap="openAccount">
      <view class="nav-tile-title">账号</view>
      <view class="nav-tile-text">登录 / 注册</view>
    </view>
    <view class="nav-tile" bindtap="openAlerts">
      <view class="nav-tile-title">告警</view>
      <view class="nav-tile-text">列表 / 详情</view>
    </view>
    <view class="nav-tile" bindtap="openSettings">
      <view class="nav-tile-title">配置</view>
      <view class="nav-tile-text">后端 / 检测</view>
    </view>
  </view>
</view>
